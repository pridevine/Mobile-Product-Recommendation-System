# Copy this file to .env and paste your key in.
# Get a free key at https://aistudio.google.com/
#
# .env is gitignored — never commit a real key. If one ever is pushed,
# revoke it in AI Studio rather than just deleting the line: it stays in
# git history.
#
# Without a key the notebook still runs; explanations fall back to the
# rule-based templates in src/ai_assistant.py.
GEMINI_API_KEY=your-key-here

# Optional. Set to 1 to make API failures raise instead of silently falling
# back to templates. Use it when demoing, so a dead API is visible.
# GALAXYMATCH_STRICT_AI=1
